# Copy this file to .env and fill in your values.

# Required: token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Comma-separated sticker file_unique_ids to count (exact, instant matching).
# Defaults to the known qrb stickers, so you usually don't need to set this.
# Discover more ids by running once with QRB_DEBUG=1 and sending the sticker(s).
# QRB_FILE_UNIQUE_IDS=AgADFSQAAnB-YVQ,AgAD-yIAAhnG6FQ

# Optional overrides (defaults shown)
# QRB_DB=qrb.db
# Timezone deciding what "today" means, e.g. Asia/Shanghai. Defaults to system tz.
# QRB_TZ=Asia/Shanghai
# Set to 1 to dump every incoming sticker (full payload to log + key fields to
# the chat) instead of counting. Use this to discover sticker file_unique_ids.
# QRB_DEBUG=1
